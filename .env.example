# SRVAS Configuration File
# Copy this to .env and update values as needed

# API Security
API_TOKEN=your-secure-token-here

# Computer Vision Settings
TARGET_FPS=15
FRAME_SKIP=1
JPEG_QUALITY=70

# Event Processing
MAX_WORKERS=3
BATCH_SIZE=3
HTTP_TIMEOUT=1.0

# Database
DB_PATH=srvas.db

# CORS Settings (comma-separated for multiple origins)
# Development: http://localhost:8000,http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:8000

# Logging
LOG_LEVEL=INFO
